generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model departments {
  id        Int         @id @default(autoincrement())
  name      String      @unique @db.VarChar(100)
  employees employees[]
}

model employees {
  id                       String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_code            String?               @unique @db.VarChar(20)
  email                    String                @unique @db.VarChar(255)
  first_name               String                @db.VarChar(100)
  last_name                String                @db.VarChar(100)
  department_id            Int?
  role                     employee_role?        @default(user)
  status                   employee_status?      @default(active)
  created_at               DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?             @default(now()) @db.Timestamptz(6)
  department               departments?          @relation(fields: [department_id], references: [id])
  employee_identities      employee_identities[]
  leave_requests_submitted leave_requests[]      @relation("submitted_by")
  leave_requests_reviewed  leave_requests[]      @relation("reviewed_by")
  event_logs               event_logs[]

  @@index([email], map: "idx_employees_email")
}

model employee_identities {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id   String         @db.Uuid
  provider      auth_provider? @default(local)
  password_hash String?        @db.VarChar(255)
  provider_id   String?        @db.VarChar(255)
  created_at    DateTime?      @default(now()) @db.Timestamptz(6)
  employees     employees      @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_id], map: "unique_provider_id")
  @@index([employee_id], map: "idx_identities_employee_id")
}

model leave_requests {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id   String        @db.Uuid
  leave_type    leave_type
  start_date    DateTime      @db.Date
  end_date      DateTime      @db.Date
  reason        String
  delegate_name String?       @db.VarChar(255)
  status        leave_status  @default(pending)
  reviewed_by   String?       @db.Uuid
  reviewed_at   DateTime?     @db.Timestamptz(6)
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  employee      employees     @relation("submitted_by", fields: [employee_id], references: [id], onDelete: Cascade)
  reviewer      employees?    @relation("reviewed_by", fields: [reviewed_by], references: [id])

  @@index([employee_id, status], map: "idx_leave_employee")
}

model event_logs {
  id          BigInt     @id @default(autoincrement())
  actor_id    String?    @db.Uuid
  actor_role  String     @db.VarChar(50)
  action      String     @db.VarChar(50)
  target_id   String?    @db.Uuid
  target_type String?    @db.VarChar(30)
  detail      Json?
  result      String     @default("success") @db.VarChar(20)
  timestamp   DateTime   @default(now()) @db.Timestamptz(6)
  actor       employees? @relation(fields: [actor_id], references: [id])

  @@index([actor_id], map: "idx_event_logs_actor")
  @@index([timestamp(sort: Desc)], map: "idx_event_logs_time")
}

enum auth_provider {
  local
  google
}

enum employee_role {
  user
  manager
  admin
}

enum employee_status {
  active
  disabled
}

enum leave_type {
  sick
  vacation
  personal
  maternity
  ordain
  other
}

enum leave_status {
  pending
  approved
  rejected
}