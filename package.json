{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "generate": "prisma generate",
    "build": "prisma generate && tsc && copyfiles -u 1 \"src/generated/**/*\" dist",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.8",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.11.11",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2",
    "vitest-mock-extended": "^3.1.1"
  }
}
